{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.shimpz.com/specs/assistant/v2/manifest.schema.json",
  "title": "Shimpz Assistant Manifest v2",
  "description": "Closed representation of shimpz.assistant.toml. allowed_hosts declares transparent network intent but never grants egress; the Team runtime owns and enforces effective policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "summary",
    "creators",
    "allowed_hosts",
    "powers"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^(?!\\s)(?!.*\\s$)[^\\r\\n]+$",
      "description": "Human-readable name. Shimpz derives and stores its immutable lowercase kebab-case id when first registered."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(?!\\s)(?!.*\\s$)[^\\r\\n]+$"
    },
    "creators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^@[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
      }
    },
    "github": {
      "type": "string",
      "maxLength": 220,
      "pattern": "^https://github\\.com/[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?/[A-Za-z0-9](?:[A-Za-z0-9._-]{0,98}[A-Za-z0-9])?$"
    },
    "allowed_hosts": {
      "description": "Exact public DNS hostnames the Assistant may contact through the Team's authenticated egress proxy. An empty array disables internet access.",
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "maxLength": 253,
        "pattern": "^(?=.{1,253}$)(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z](?:[a-z0-9-]{0,61}[a-z0-9])?$"
      }
    },
    "powers": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 128,
      "propertyNames": {
        "$ref": "#/$defs/id"
      },
      "additionalProperties": {
        "$ref": "#/$defs/power"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "power": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^(?!\\s)(?!.*\\s$)[^\\r\\n]+$"
        },
        "approval": {
          "description": "Defaults to never when omitted.",
          "enum": [
            "never",
            "once",
            "always"
          ]
        }
      }
    }
  }
}
