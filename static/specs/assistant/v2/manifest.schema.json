{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.shimpz.com/specs/assistant/v2/manifest.schema.json",
  "title": "Shimpz Assistant Manifest v2",
  "description": "Closed, intent-only representation of shimpz.assistant.toml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "name", "summary", "creators", "powers"],
  "properties": {
    "schema_version": { "const": 2 },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^(?!\\s)(?!.*\\s$)[^\\r\\n]+$"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(?!\\s)(?!.*\\s$)[^\\r\\n]+$"
    },
    "creators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^@[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
      }
    },
    "github": {
      "type": "string",
      "maxLength": 200,
      "pattern": "^https://github\\.com/[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?/[A-Za-z0-9._-]+/?$"
    },
    "powers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$": { "$ref": "#/$defs/power" }
      }
    }
  },
  "$defs": {
    "power": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^(?!\\s)(?!.*\\s$)[^\\r\\n]+$"
        },
        "approval": {
          "enum": ["never", "once", "always"],
          "default": "never"
        }
      }
    }
  }
}
