{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.shimpz.com/specs/assistant/manifest.schema.json",
  "title": "Shimpz Assistant Manifest",
  "description": "Closed representation of shimpz.assistant.toml. Accounts and Secrets declare public dependency intent without private values; allowed_hosts declares transparent network intent but never grants egress. The Team runtime owns and enforces effective policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "summary",
    "creators",
    "allowed_hosts",
    "powers"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^(?!\\s)(?!.*\\s$)[^\\r\\n]+$",
      "description": "Human-readable name. Shimpz derives and stores its immutable lowercase kebab-case id when first registered."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(?!\\s)(?!.*\\s$)[^\\r\\n]+$"
    },
    "creators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^@[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
      }
    },
    "github": {
      "type": "string",
      "maxLength": 220,
      "pattern": "^https://github\\.com/[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?/[A-Za-z0-9](?:[A-Za-z0-9._-]{0,98}[A-Za-z0-9])?$"
    },
    "allowed_hosts": {
      "description": "Exact public DNS hostnames the Assistant may contact through the Team's authenticated egress proxy. An empty array disables internet access.",
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "maxLength": 253,
        "pattern": "^(?!.*\\.(?:arpa|example|home|internal|invalid|lan|local|localdomain|localhost|onion|test)$)(?=.{1,253}$)(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z](?:[a-z0-9-]{0,61}[a-z0-9])?$"
      }
    },
    "secrets": {
      "description": "Public metadata for opaque Team-scoped values that the controller may provide only to Powers that reference them.",
      "type": "object",
      "maxProperties": 32,
      "propertyNames": {
        "$ref": "#/$defs/secretId"
      },
      "additionalProperties": {
        "$ref": "#/$defs/secret"
      }
    },
    "accounts": {
      "description": "Public provider and scope intent for controller-owned OAuth Accounts. Authorization endpoints, client credentials and tokens are never declared by an Assistant.",
      "type": "object",
      "maxProperties": 16,
      "propertyNames": {
        "$ref": "#/$defs/accountId"
      },
      "additionalProperties": {
        "$ref": "#/$defs/account"
      }
    },
    "powers": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 128,
      "propertyNames": {
        "$ref": "#/$defs/id"
      },
      "additionalProperties": {
        "$ref": "#/$defs/power"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "secretId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "accountId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "scope": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z][a-z0-9]*(?:[._:-][a-z0-9]+)*$"
    },
    "account": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "scopes"
      ],
      "properties": {
        "provider": {
          "$ref": "#/$defs/accountId"
        },
        "scopes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/scope"
          }
        }
      }
    },
    "secret": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "summary"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^(?!\\s)(?!.*\\s$)[^\\r\\n]+$"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^(?!\\s)(?!.*\\s$)[^\\r\\n]+$"
        }
      }
    },
    "power": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^(?!\\s)(?!.*\\s$)[^\\r\\n]+$"
        },
        "approval": {
          "description": "Defaults to never when omitted.",
          "enum": [
            "never",
            "once",
            "always"
          ]
        },
        "secrets": {
          "description": "Opaque secret ids this Power requires. The controller resolves values just in time and never exposes them to the Brain.",
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/secretId"
          }
        },
        "accounts": {
          "description": "Controller-owned Account ids this Power requires. The controller resolves a short-lived private envelope just in time and never exposes tokens to the Brain.",
          "type": "array",
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/accountId"
          }
        }
      }
    }
  }
}
