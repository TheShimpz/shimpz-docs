:8080 {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https: wss:; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
	}
	root * /srv

	# The tunnel sends both public hostnames to this deliberately small origin. Keep the installer
	# uncached so every invocation resolves the current digest-pinning bootstrap.
	@installer {
		host install.shimpz.com
		path / /install.sh
	}
	handle @installer {
		header Content-Type "text/x-shellscript; charset=utf-8"
		header Cache-Control "no-store"
		rewrite * /install.sh
		file_server
	}
	@installer_missing host install.shimpz.com
	handle @installer_missing {
		respond 404
	}

	# Prerendered routes are directories because SvelteKit uses trailingSlash=always. Never fall
	# back to the homepage: a missing Docs URL is a real 404 and is part of the public edge contract.
	handle {
		try_files {path} {path}/ =404
		file_server
	}
	encode gzip
}
